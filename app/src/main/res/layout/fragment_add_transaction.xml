<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/appBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surfaceCard"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tv_form_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Manual Transaction"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/surfaceCard"
            android:layout_margin="16dp"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="What was it for? *"
                android:textSize="13sp"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_merchant"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="e.g. Auto Rickshaw, Samosa, Notebook"
                android:background="@color/appBackground"
                android:paddingHorizontal="14dp"
                android:inputType="text"
                android:textSize="15sp"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textSecondary"
                android:layout_marginBottom="18dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Amount (₹) *"
                android:textSize="13sp"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_amount"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="e.g. 150"
                android:background="@color/appBackground"
                android:paddingHorizontal="14dp"
                android:inputType="numberDecimal"
                android:textSize="15sp"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textSecondary"
                android:layout_marginBottom="18dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category *"
                android:textSize="13sp"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/spinner_category"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@color/appBackground"
                android:paddingHorizontal="8dp"
                android:layout_marginBottom="18dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Note (optional)"
                android:textSize="13sp"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_note"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:hint="e.g. Paid cash at college gate"
                android:background="@color/appBackground"
                android:paddingHorizontal="14dp"
                android:paddingTop="12dp"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:textSize="14sp"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textSecondary"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Save Transaction"
                android:backgroundTint="@color/red_expense"
                android:textColor="@color/textOnBrand"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btn_delete"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Delete Transaction"
                android:backgroundTint="@color/red_expense"
                android:textColor="@color/textOnBrand"
                android:textSize="15sp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>